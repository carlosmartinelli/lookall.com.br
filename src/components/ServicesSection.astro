---
const services = [
  {
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    title: 'Atração de Clientes',
    description: 'Estratégias multicanal para atrair o público certo para o seu negócio.',
    color: '#f5c518',
  },
  {
    icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
    title: 'Digital & Analytics',
    description: 'Dashboards e relatórios que transformam dados em decisões inteligentes.',
    color: '#2e5bff',
  },
  {
    icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    title: 'Inbound Marketing',
    description: 'Conteúdo estratégico que educa, engaja e converte visitantes em clientes.',
    color: '#1fbf6b',
  },
  {
    icon: 'M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z',
    title: 'Redes Sociais',
    description: 'Gestão completa de social media com foco em comunidade e conversão.',
    color: '#8b5cf6',
  },
  {
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
    title: 'Desenvolvimento de Sites',
    description: 'Sites e sistemas web rápidos, bonitos e otimizados para converter.',
    color: '#f97316',
  },
];
---

<section
  id="servicos"
  class="py-20 px-4 sm:px-6 lg:px-8"
  style="background: linear-gradient(180deg, #0f1728 0%, #1e2a4a 100%);"
  aria-labelledby="services-heading"
>
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-14">
      <span class="text-sm font-bold text-[#f5c518] uppercase tracking-widest">O que fazemos</span>
      <h2
        id="services-heading"
        class="mt-3 text-3xl md:text-4xl lg:text-5xl font-black text-white text-balance"
      >
        Nossos <span class="text-[#f5c518]">Serviços</span>
      </h2>
      <p class="mt-4 text-lg text-white/60 max-w-xl mx-auto">
        Soluções integradas de tecnologia e marketing para fazer o seu negócio crescer de verdade.
      </p>
    </div>

    <!-- Services grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {services.map((service) => (
        <article
          class="group bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-7 hover:bg-white/10 hover:border-white/20 transition-all duration-300 hover:-translate-y-1 cursor-pointer"
        >
          <div
            class="w-12 h-12 rounded-xl flex items-center justify-center mb-5"
            style={`background: ${service.color}20; border: 1px solid ${service.color}40;`}
          >
            <svg
              class="w-6 h-6"
              style={`color: ${service.color};`}
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={service.icon} />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2 group-hover:text-[#f5c518] transition-colors">
            {service.title}
          </h3>
          <p class="text-sm text-white/60 leading-relaxed">{service.description}</p>
        </article>
      ))}

      <!-- Center phone image card -->
      <div class="sm:col-span-2 lg:col-span-1 relative flex items-center justify-center bg-white/5 border border-white/10 rounded-2xl overflow-hidden min-h-[200px] lg:row-span-1">
        <div class="absolute inset-0 bg-gradient-to-br from-[#f5c518]/10 to-[#2e5bff]/10"></div>
        <img
          src="/hero-image.png"
          alt="App Lookall no smartphone"
          class="relative z-10 w-40 mx-auto drop-shadow-2xl"
          loading="lazy"
          width="160"
          height="240"
        />
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center">
      <a
        href="#contato"
        class="inline-flex items-center gap-2 px-8 py-4 border-2 border-[#f5c518] text-[#f5c518] font-bold rounded-full hover:bg-[#f5c518] hover:text-[#0b0f1a] transition-all duration-200"
        aria-label="Ver todos os serviços"
      >
        Ver Todos os Serviços
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
