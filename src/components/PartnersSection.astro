---
// Partner logos represented as text names (replace with actual logo <img> tags when available)
const partners = [
  { name: 'Google', abbr: 'G' },
  { name: 'Meta', abbr: 'M' },
  { name: 'HubSpot', abbr: 'H' },
  { name: 'RD Station', abbr: 'RD' },
  { name: 'Shopify', abbr: 'S' },
  { name: 'WordPress', abbr: 'WP' },
  { name: 'Stripe', abbr: 'ST' },
  { name: 'Mailchimp', abbr: 'MC' },
  { name: 'Semrush', abbr: 'SR' },
  { name: 'Hotjar', abbr: 'HJ' },
];
---

<section
  id="parceiros"
  class="bg-[#fafbfd] py-16 px-4 sm:px-6 lg:px-8"
  aria-labelledby="partners-heading"
>
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row items-center justify-between mb-10 gap-4">
      <h2
        id="partners-heading"
        class="text-2xl font-black text-[#0b0f1a]"
      >
        Alguns dos nossos <span class="text-[#2e5bff]">parceiros</span>
      </h2>
      <a href="#contato" class="text-sm font-semibold text-[#2e5bff] hover:underline flex items-center gap-1">
        Ver Todos
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>

    <!-- Logo grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
      {partners.map((partner) => (
        <div class="group flex items-center justify-center p-5 bg-white border border-[#e8eaee] rounded-xl hover:border-[#f5c518] hover:shadow-md transition-all duration-300 cursor-pointer">
          <!-- Logo placeholder — replace with <img> when logo files are available -->
          <div class="flex flex-col items-center gap-1">
            <div class="w-10 h-10 rounded-lg bg-[#e8eaee] group-hover:bg-[#f5c518]/10 flex items-center justify-center transition-colors">
              <span class="text-sm font-black text-[#5b6473] group-hover:text-[#0b0f1a] transition-colors">{partner.abbr}</span>
            </div>
            <span class="text-xs font-semibold text-[#5b6473] group-hover:text-[#0b0f1a] transition-colors">{partner.name}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
