---
const features = [
  {
    title: 'Estratégia personalizada para o seu mercado',
    body: 'Não vendemos pacotes genéricos. Criamos uma operação digital feita para o seu nicho, seu público e seu momento.',
  },
  {
    title: 'IA e automação aplicadas ao seu negócio',
    body: 'Fluxos automáticos de captação, nutrição e qualificação de leads — para que sua equipe foque no que realmente importa.',
  },
  {
    title: 'Time completo pelo custo de um funcionário',
    body: 'Designer, dev, redator, trafegista e estrategista numa parceria única. Escala quando você precisar, sem dor de cabeça de RH.',
  },
];
---

<section
  id="crescimento"
  class="bg-white py-20 px-4 sm:px-6 lg:px-8"
  aria-labelledby="growth-heading"
>
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left: text + accordion + CTA -->
      <div>
        <span class="text-sm font-bold text-[#1fbf6b] uppercase tracking-widest">Cresça com a gente!</span>
        <h2
          id="growth-heading"
          class="mt-3 text-3xl md:text-4xl lg:text-5xl font-black text-[#0b0f1a] leading-tight mb-6"
        >
          A parceria que faltava<br />para escalar de verdade
        </h2>
        <p class="text-lg text-[#5b6473] leading-relaxed mb-8">
          Combinamos tecnologia, estratégia e criatividade para gerar crescimento real e mensurável — sem achismo e com dados.
        </p>

        <!-- Accordion features -->
        <div class="space-y-3 mb-8">
          {features.map((item, i) => (
            <details class="group border border-[#e8eaee] rounded-xl overflow-hidden" open={i === 0}>
              <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none select-none bg-[#fafbfd] group-open:bg-[#f5c518]/8">
                <span class="font-semibold text-[#0b0f1a] text-sm pr-4">{item.title}</span>
                <span class="chevron flex-shrink-0 w-5 h-5 text-[#5b6473] group-open:text-[#f5c518] transition-transform duration-300" aria-hidden="true">
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </span>
              </summary>
              <div class="px-5 pb-4 pt-2 bg-white">
                <p class="text-sm text-[#5b6473] leading-relaxed">{item.body}</p>
              </div>
            </details>
          ))}
        </div>

        <div class="flex flex-wrap gap-4">
          <a
            href="#contato"
            class="inline-flex items-center gap-2 px-7 py-3.5 bg-[#f5c518] text-[#0b0f1a] font-black rounded-full hover:bg-[#e6b800] transition-all hover:shadow-lg hover:-translate-y-0.5"
          >
            Agendar Diagnóstico
          </a>
          <a
            href="#servicos"
            class="inline-flex items-center gap-2 px-7 py-3.5 border-2 border-[#0b0f1a] text-[#0b0f1a] font-bold rounded-full hover:bg-[#0b0f1a] hover:text-white transition-all"
          >
            Ver serviços
          </a>
        </div>
      </div>

      <!-- Right: colorful illustration -->
      <div class="relative hidden lg:flex items-center justify-center" aria-hidden="true">
        <!-- Main card -->
        <div class="relative w-full max-w-md">
          <!-- Background decoration -->
          <div class="absolute -top-8 -right-8 w-48 h-48 bg-[#f5c518]/15 rounded-full blur-3xl"></div>
          <div class="absolute -bottom-8 -left-8 w-48 h-48 bg-[#2e5bff]/10 rounded-full blur-3xl"></div>

          <!-- Dashboard card -->
          <div class="relative bg-white border border-[#e8eaee] rounded-3xl p-8 shadow-xl">
            <div class="flex items-center justify-between mb-6">
              <div>
                <p class="text-xs text-[#5b6473] uppercase tracking-wider font-semibold">Desempenho mensal</p>
                <p class="text-2xl font-black text-[#0b0f1a] mt-1">+312% orgânico</p>
              </div>
              <div class="w-12 h-12 bg-[#f5c518]/15 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-[#f5c518]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                </svg>
              </div>
            </div>

            <!-- Chart bars -->
            <div class="flex items-end gap-1.5 h-28 mb-6">
              {[22, 35, 28, 48, 40, 55, 50, 68, 62, 80, 74, 100].map((h, i) => (
                <div
                  class="flex-1 rounded-t-sm"
                  style={`height:${h}%; background: ${i >= 9 ? '#f5c518' : i >= 6 ? '#2e5bff40' : '#e8eaee'};`}
                ></div>
              ))}
            </div>

            <!-- Metric rows -->
            <div class="space-y-3">
              {[
                { label: 'Leads gerados', value: '+89%', color: '#2e5bff' },
                { label: 'Taxa de conversão', value: '4.7%', color: '#1fbf6b' },
                { label: 'ROI da campanha', value: '2.4x', color: '#f5c518' },
              ].map((m) => (
                <div class="flex items-center justify-between py-2 border-t border-[#e8eaee]">
                  <span class="text-sm text-[#5b6473]">{m.label}</span>
                  <span class="text-sm font-bold" style={`color: ${m.color}`}>{m.value}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Floating badge -->
          <div class="absolute -top-4 -left-4 bg-[#1fbf6b] text-white font-black text-xs px-4 py-2 rounded-full shadow-lg">
            Resultado real ✓
          </div>

          <!-- Floating stat pill -->
          <div class="absolute -bottom-4 right-6 bg-white border border-[#e8eaee] shadow-lg rounded-full px-4 py-2 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-[#f5c518]"></span>
            <span class="text-xs font-bold text-[#0b0f1a]">+106 empresas crescendo</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
