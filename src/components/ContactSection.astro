---
---

<section
  id="contato"
  class="bg-[#f7f7f7] py-20 px-4 sm:px-6 lg:px-8"
  aria-labelledby="contato-heading"
>
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

    <!-- Left: copy -->
    <div class="lg:sticky lg:top-24">
      <span class="text-sm font-bold text-[#f5c518] uppercase tracking-widest">Contato</span>
      <h2
        id="contato-heading"
        class="mt-3 text-3xl md:text-4xl lg:text-5xl font-black text-[#0b0f1a] leading-tight text-balance"
      >
        Vamos fazer o seu negócio <span class="text-[#2e5bff]">crescer juntos?</span>
      </h2>
      <p class="mt-6 text-lg text-[#5b6473] leading-relaxed">
        Agende um diagnóstico gratuito. Em 30 minutos mapeamos os maiores gargalos do seu negócio e apresentamos um plano de ação prático.
      </p>

      <!-- Highlights -->
      <ul class="mt-8 space-y-4">
        {[
          'Diagnóstico 100% gratuito e sem compromisso',
          'Resposta em até 1 dia útil',
          'Atendimento para todo o Brasil',
        ].map((item) => (
          <li class="flex items-center gap-3">
            <span class="w-5 h-5 rounded-full bg-[#1fbf6b]/15 flex items-center justify-center flex-shrink-0">
              <svg class="w-3 h-3 text-[#1fbf6b]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
              </svg>
            </span>
            <span class="text-sm font-medium text-[#374151]">{item}</span>
          </li>
        ))}
      </ul>

      <!-- WhatsApp shortcut -->
      <div class="mt-10 flex items-center gap-4 p-5 bg-white border border-[#e8eaee] rounded-2xl">
        <div class="w-11 h-11 bg-[#1fbf6b]/10 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-[#1fbf6b]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.136.563 4.14 1.545 5.874L0 24l6.299-1.52A11.953 11.953 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-4.991-1.363l-.358-.212-3.741.903.943-3.638-.233-.374A9.817 9.817 0 012.182 12C2.182 6.56 6.56 2.182 12 2.182S21.818 6.56 21.818 12 17.44 21.818 12 21.818z"/>
          </svg>
        </div>
        <div>
          <p class="text-xs text-[#5b6473] mb-0.5">Prefere pelo WhatsApp?</p>
          <a
            href="https://wa.me/5511999999999"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-bold text-[#0b0f1a] hover:text-[#1fbf6b] transition-colors"
            aria-label="Falar no WhatsApp"
          >
            Clique aqui para conversar &rarr;
          </a>
        </div>
      </div>
    </div>

    <!-- Right: form -->
    <div class="bg-white border border-[#e8eaee] rounded-3xl p-8 shadow-sm">
      <form
        name="contato"
        method="POST"
        action="#"
        class="space-y-5"
        novalidate
      >
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="nome" class="block text-sm font-semibold text-[#0b0f1a] mb-1.5">
              Nome <span class="text-[#f97316]" aria-hidden="true">*</span>
            </label>
            <input
              type="text"
              id="nome"
              name="nome"
              required
              autocomplete="given-name"
              placeholder="Seu nome"
              class="w-full px-4 py-3 bg-[#fafbfd] border border-[#e8eaee] rounded-xl text-sm text-[#0b0f1a] placeholder-[#a0aab4] focus:outline-none focus:border-[#f5c518] focus:ring-2 focus:ring-[#f5c518]/20 transition-colors"
            />
          </div>
          <div>
            <label for="empresa" class="block text-sm font-semibold text-[#0b0f1a] mb-1.5">
              Empresa
            </label>
            <input
              type="text"
              id="empresa"
              name="empresa"
              autocomplete="organization"
              placeholder="Nome da empresa"
              class="w-full px-4 py-3 bg-[#fafbfd] border border-[#e8eaee] rounded-xl text-sm text-[#0b0f1a] placeholder-[#a0aab4] focus:outline-none focus:border-[#f5c518] focus:ring-2 focus:ring-[#f5c518]/20 transition-colors"
            />
          </div>
        </div>

        <div>
          <label for="email" class="block text-sm font-semibold text-[#0b0f1a] mb-1.5">
            E-mail <span class="text-[#f97316]" aria-hidden="true">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            placeholder="seu@email.com.br"
            class="w-full px-4 py-3 bg-[#fafbfd] border border-[#e8eaee] rounded-xl text-sm text-[#0b0f1a] placeholder-[#a0aab4] focus:outline-none focus:border-[#f5c518] focus:ring-2 focus:ring-[#f5c518]/20 transition-colors"
          />
        </div>

        <div>
          <label for="whatsapp" class="block text-sm font-semibold text-[#0b0f1a] mb-1.5">
            WhatsApp <span class="text-[#f97316]" aria-hidden="true">*</span>
          </label>
          <input
            type="tel"
            id="whatsapp"
            name="whatsapp"
            required
            autocomplete="tel"
            placeholder="(11) 99999-9999"
            class="w-full px-4 py-3 bg-[#fafbfd] border border-[#e8eaee] rounded-xl text-sm text-[#0b0f1a] placeholder-[#a0aab4] focus:outline-none focus:border-[#f5c518] focus:ring-2 focus:ring-[#f5c518]/20 transition-colors"
          />
        </div>

        <div>
          <label for="mensagem" class="block text-sm font-semibold text-[#0b0f1a] mb-1.5">
            Como podemos ajudar?
          </label>
          <textarea
            id="mensagem"
            name="mensagem"
            rows="4"
            placeholder="Conte um pouco sobre o seu negócio e seus objetivos..."
            class="w-full px-4 py-3 bg-[#fafbfd] border border-[#e8eaee] rounded-xl text-sm text-[#0b0f1a] placeholder-[#a0aab4] focus:outline-none focus:border-[#f5c518] focus:ring-2 focus:ring-[#f5c518]/20 transition-colors resize-none"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full flex items-center justify-center gap-2 px-6 py-4 bg-[#f5c518] text-[#0b0f1a] font-black rounded-xl hover:bg-[#e6b800] active:scale-[0.98] transition-all duration-200 shadow-md hover:shadow-lg"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          Agendar Diagnóstico Gratuito
        </button>

        <p class="text-xs text-center text-[#a0aab4]">
          Ao enviar, você concorda com nossa
          <a href="#" class="underline hover:text-[#5b6473] transition-colors">Política de Privacidade</a>.
        </p>
      </form>
    </div>

  </div>
</section>
