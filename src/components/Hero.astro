---
const serviceChips = [
  'CRM & Vendas',
  'Automação & IA',
  'Sites & Software',
  'SEO & Tráfego',
];
---

<section
  id="hero"
  class="relative overflow-hidden bg-white pt-24 pb-16 lg:pt-32 lg:pb-24 px-4 sm:px-6 lg:px-8"
  aria-label="Seção principal"
>
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

    <!-- Left: Text Content -->
    <div class="space-y-8 relative z-10">
      <!-- Eyebrow badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-[#f5c518]/10 border border-[#f5c518]/30 rounded-full">
        <span class="w-2 h-2 rounded-full bg-[#f5c518] animate-pulse"></span>
        <span class="text-sm font-semibold text-[#0b0f1a] tracking-wide">
          Tecnologia &middot; Automação &middot; Crescimento Local
        </span>
      </div>

      <!-- H1 -->
      <h1 class="text-4xl md:text-5xl lg:text-5xl xl:text-6xl font-black leading-tight text-[#0b0f1a] text-balance">
        Parceria
        <span style="color:#f5c518">Tecnológica</span>
        IA e Marketing para ajudar a sua empresa a
        <span style="color:#f5c518">Crescer</span>
      </h1>

      <!-- Body -->
      <p class="text-lg text-[#5b6473] max-w-lg leading-relaxed">
        Utilizamos nossa expertise em desenvolvimento de websites e estratégias de marketing digital para impulsionar o sucesso de empresas de todos os setores.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4">
        <a
          href="#contato"
          class="inline-flex items-center gap-2 px-6 py-3 bg-[#f5c518] text-[#0b0f1a] font-bold rounded-full hover:bg-[#e6b800] transition-all duration-200 shadow-md hover:shadow-lg hover:-translate-y-0.5"
          aria-label="Agendar diagnóstico gratuito"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          Agendar diagnóstico gratuito
        </a>
        <a
          href="https://wa.me/5511999999999"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 bg-[#1fbf6b] text-white font-bold rounded-full hover:bg-[#17a85e] transition-all duration-200 shadow-md hover:shadow-lg hover:-translate-y-0.5"
          aria-label="Falar no WhatsApp"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.136.563 4.14 1.545 5.874L0 24l6.299-1.52A11.953 11.953 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-4.991-1.363l-.358-.212-3.741.903.943-3.638-.233-.374A9.817 9.817 0 012.182 12C2.182 6.56 6.56 2.182 12 2.182S21.818 6.56 21.818 12 17.44 21.818 12 21.818z"/>
          </svg>
          Falar no WhatsApp
        </a>
      </div>

      <!-- Service Chips -->
      <div class="flex flex-wrap gap-2" aria-label="Nossos serviços">
        {serviceChips.map((chip) => (
          <span class="px-4 py-2 bg-[#fafbfd] border border-[#e8eaee] text-sm font-medium text-[#374151] rounded-full hover:border-[#f5c518] hover:bg-[#f5c518]/5 transition-colors cursor-default">
            {chip}
          </span>
        ))}
      </div>
    </div>

    <!-- Right: Phone Mockup + Blob -->
    <div class="relative flex items-center justify-center lg:justify-end">
      <!-- Animated yellow blob -->
      <div
        class="blob-animate absolute inset-0 m-auto w-80 h-80 lg:w-96 lg:h-96 bg-[#f5c518]/20 -z-0"
        aria-hidden="true"
      ></div>

      <!-- Phone image -->
      <div class="relative z-10">
        <img
          src="/hero-image.png"
          alt="Aplicativo Lookall em smartphone mostrando o dashboard de marketing"
          class="w-full max-w-sm mx-auto drop-shadow-2xl"
          loading="eager"
          width="400"
          height="600"
        />

        <!-- Floating card: top-left -->
        <div class="absolute -top-4 -left-4 bg-white border border-[#e8eaee] rounded-xl px-4 py-3 shadow-lg flex items-center gap-3 z-20">
          <div class="w-9 h-9 bg-[#2e5bff]/10 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-[#2e5bff]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <div>
            <p class="text-xs text-[#5b6473] leading-none mb-0.5">Consultoria</p>
            <p class="text-sm font-bold text-[#0b0f1a]">Estratégica</p>
          </div>
        </div>

        <!-- Floating card: bottom-right -->
        <div class="absolute -bottom-4 -right-4 bg-white border border-[#e8eaee] rounded-xl px-4 py-3 shadow-lg flex items-center gap-3 z-20">
          <div class="w-9 h-9 bg-[#1fbf6b]/10 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-[#1fbf6b]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <div>
            <p class="text-xs text-[#5b6473] leading-none mb-0.5">IA &amp;</p>
            <p class="text-sm font-bold text-[#0b0f1a]">Automação</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
