---
const navLinks = [
  { label: 'Agência', href: '#agencia' },
  { label: 'Serviços', href: '#servicos' },
  { label: 'Blog', href: '#blog' },
  { label: 'Contato', href: '#contato' },
  { label: 'FAQ', href: '#faq' },
];

const serviceLinks = [
  { label: 'CRM & Vendas', href: '#servicos' },
  { label: 'Automação & IA', href: '#servicos' },
  { label: 'Sites & Software', href: '#servicos' },
  { label: 'SEO & Tráfego', href: '#servicos' },
  { label: 'Redes Sociais', href: '#servicos' },
  { label: 'Email Marketing', href: '#servicos' },
];

const resourceLinks = [
  { label: 'Blog', href: '#blog' },
  { label: 'Cases de Sucesso', href: '#resultados' },
  { label: 'Diagnóstico Gratuito', href: '#contato' },
  { label: 'Política de Privacidade', href: '#' },
  { label: 'Termos de Uso', href: '#' },
];

const socialLinks = [
  {
    label: 'Instagram',
    href: 'https://instagram.com/lookall',
