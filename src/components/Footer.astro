const currentYear = new Date().getFullYear();
---

<footer
  style="background: #0b0f1a;"
  class="text-white"
  aria-label="Rodapé"
>
  <!-- Main footer content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-10 lg:gap-8">

      <!-- Brand + Social -->
      <div class="lg:col-span-2">
        <a href="/" class="inline-block mb-6" aria-label="Lookall - página inicial">
          <img
            src="/logo.png"
            alt="Lookall"
            width="150"
            height="42"
            class="h-9 w-auto invert"
            loading="lazy"
          />
        </a>
        <p class="text-white/60 text-sm leading-relaxed max-w-xs mb-6">
          Parceria tecnológica IA e marketing digital para fazer o seu negócio crescer de verdade.
        </p>
        <!-- Social icons -->
        <div class="flex items-center gap-4">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-lg bg-white/10 hover:bg-[#f5c518] flex items-center justify-center transition-colors group"
              aria-label={social.label}
            >
              <svg class="w-4 h-4 text-white/70 group-hover:text-[#0b0f1a] transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d={social.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-sm font-bold text-white uppercase tracking-widest mb-5">Navegação</h3>
        <ul class="space-y-3">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-white/60 hover:text-[#f5c518] transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-bold text-white uppercase tracking-widest mb-5">Serviços</h3>
        <ul class="space-y-3">
          {serviceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-white/60 hover:text-[#f5c518] transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources + Contact -->
      <div class="space-y-8">
        <div>
          <h3 class="text-sm font-bold text-white uppercase tracking-widest mb-5">Recursos</h3>
          <ul class="space-y-3">
            {resourceLinks.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-white/60 hover:text-[#f5c518] transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-bold text-white uppercase tracking-widest mb-4">Contato</h3>
          <ul class="space-y-2">
            <li>
              <a href="mailto:ola@lookall.com.br" class="text-sm text-white/60 hover:text-[#f5c518] transition-colors">
                ola@lookall.com.br
              </a>
            </li>
            <li>
              <a href="https://wa.me/5511999999999" class="text-sm text-white/60 hover:text-[#f5c518] transition-colors">
                +55 (11) 99999-9999
              </a>
            </li>
            <li class="text-sm text-white/40">
              São Paulo, SP - Brasil
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Google Maps embed -->
    <div class="mt-12 rounded-2xl overflow-hidden border border-white/10" aria-label="Localização no mapa">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3657.045127700697!2d-46.65428482375705!3d-23.563809161460043!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94ce59c8da0aa315%3A0xd59f9431f2c9776a!2sAv.%20Paulista%2C%20S%C3%A3o%20Paulo%20-%20SP!5e0!3m2!1spt-BR!2sbr!4v1715177655!5m2!1spt-BR!2sbr"
        width="100%"
        height="240"
        style="border:0;"
        allowfullscreen={false}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Localização Lookall - São Paulo"
      ></iframe>
    </div>
  </div>

  <!-- Copyright row -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-xs text-white/40">
        &copy; {currentYear} Lookall. Todos os direitos reservados.
      </p>
      <p class="text-xs text-white/40">
        Feito com dedicação no Brasil.
      </p>
    </div>
  </div>
</footer>
