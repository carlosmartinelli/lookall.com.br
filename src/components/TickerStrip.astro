---
const items = [
  'Fluxos com IA',
  'Agendamento Automático',
  'Painel De Dados',
  'Website Customizado',
  'CMS Customizado',
  'CRM & Vendas',
  'SEO Avançado',
  'Tráfego Pago',
  'Email Marketing',
  'Redes Sociais',
];
// Duplicate items for seamless loop
const doubled = [...items, ...items];
---

<section
  class="bg-[#0b0f1a] py-4 overflow-hidden"
  aria-label="Serviços e especialidades"
>
  <h2 class="sr-only">Nossas especialidades e serviços</h2>

  <div class="flex items-center whitespace-nowrap overflow-hidden">
    <div class="ticker-track inline-flex items-center gap-0 flex-shrink-0">
      {doubled.map((item) => (
        <span class="inline-flex items-center gap-3 mx-8 text-white font-bold text-sm sm:text-base tracking-wide uppercase">
          <span class="w-2.5 h-2.5 rounded-full bg-[#f5c518] flex-shrink-0" aria-hidden="true"></span>
          {item}
        </span>
      ))}
    </div>
  </div>
</section>
